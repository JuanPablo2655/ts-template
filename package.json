{
	"name": "ts-template",
	"version": "0.1.0",
	"description": "A template for TypeScript projects",
	"main": "dist/index.js",
	"type": "module",
	"imports": {
		"#lib/*": "./dist/lib/*.js",
		"#root/*": "./dist/*.js"
	},
	"scripts": {
		"build": "tsc -b src",
		"dev": "pnpm build && pnpm start",
		"lint": "eslint --fix --ext ts src tests",
		"format": "prettier --write .",
		"start": "node --enable-source-maps dist/index.js",
		"postinstall": "husky || true",
		"test": "vitest run",
		"test:format": "prettier --check ."
	},
	"repository": "git@github.com:JuanPablo2655/ts-template.git",
	"author": "JuanPablo2655 <personal@isidrocasiano.com>",
	"license": "MIT",
	"private": true,
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-angular": "^20.5.0",
		"@types/eslint": "^9.6.1",
		"@types/node": "^25.6.0",
		"@vitest/coverage-v8": "^4.1.4",
		"eslint": "^10.2.0",
		"eslint-config-neon": "^0.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.1.1",
		"tslib": "^2.6.2",
		"typescript": "^6.0.2",
		"vite": "^6.4.1",
		"vitest": "^4.1.4"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"lint-staged": {
		"*": "prettier --ignore-unknown --write",
		"*.{.mjs,js,ts}": "eslint --fix --ext mjs,js,ts"
	}
}
